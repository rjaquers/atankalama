<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^$ public/ [L]
    RewriteRule (.*) public/$1 [L]
</IfModule>

# Seguridad: Bloquear acceso directo a archivos sensibles
<FilesMatch "(\.env|\.git|composer\.(json|lock)|ftp_sync\.py)$">
    Order deny,allow
    Deny from all
</FilesMatch>
